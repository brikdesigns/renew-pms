# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (transactional email)
RESEND_API_KEY=your-resend-key

# Site URL (used for email redirect links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret — gates POST /api/cron/generate-daily-tasks. The Netlify
# scheduled function at netlify/functions/cron-daily-tasks.mts sends this
# as a Bearer token. Generate with `openssl rand -hex 32`. Set the same
# value in Netlify env vars (production + staging contexts) and 1Password.
# CRON_SECRET=

# Sentry (error tracking — optional in development)
# SENTRY_AUTH_TOKEN=
# NEXT_PUBLIC_SENTRY_DSN=

# Dev tools — controls the internal-only BrikDevBar (persona switcher, inspect,
# feedback widget rendered as a slot). Set to "true" on the staging Netlify
# context. NEVER set on the production Netlify context — the persona switcher
# would be visible to real customers.
# NEXT_PUBLIC_ENABLE_DEV_TOOLS=

# Customer feedback FAB — enables the BDS DevFeedbackWidget as a standalone
# floating action button (no DevBar shell, no persona switcher). Set to "true"
# on the production Netlify context for the beta feedback path.
# NEXT_PUBLIC_ENABLE_FEEDBACK_FAB=

# Analytics (TBD)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Back-office integrations (TBD — e.g. Dentrix, Open Dental)
# DENTAL_API_KEY=
# DENTAL_API_URL=
