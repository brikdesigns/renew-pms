#!/usr/bin/env sh

# ── Branch hygiene checks ──
# Enforces task/{scope}-{name} naming and warns if branch diverged from staging
# instead of main. Catches the "branched from wrong base" problem early.
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "staging" ]; then
  # Check branch naming convention
  case "$CURRENT_BRANCH" in
    task/*) ;; # valid
    *)
      echo ""
      echo "WARNING: Branch '$CURRENT_BRANCH' doesn't follow task/{scope}-{name} convention."
      echo "  Expected: task/renew-task-templates, task/auth-session-fix, etc."
      echo "  Create branches with: ./scripts/new-task.sh {scope}-{name}"
      echo ""
      ;;
  esac

  # Check if branch is too far ahead of main (likely based on staging)
  git fetch origin main --quiet 2>/dev/null || true
  COMMITS_AHEAD=$(git log --oneline "origin/main..HEAD" 2>/dev/null | wc -l | tr -d ' ')
  if [ "$COMMITS_AHEAD" -gt 20 ]; then
    echo ""
    echo "WARNING: Branch is ${COMMITS_AHEAD} commits ahead of main."
    echo "  This may indicate the branch was based on staging instead of main."
    echo "  If so, rebase onto main before merging: git rebase origin/main"
    echo ""
  fi
fi

# ── Dependency file check ──
# Ensures package.json/lock file changes are committed before pushing.
DIRTY_PKG=$(git diff --name-only -- package.json package-lock.json)
if [ -n "$DIRTY_PKG" ]; then
  echo "ERROR: Uncommitted changes in dependency files:"
  echo "$DIRTY_PKG"
  echo "Commit these before pushing or Netlify build will fail."
  exit 1
fi

# ── Migration conflict detection ──
# Catches the most dangerous multi-agent scenario: two branches create the
# same migration number. Detected at push time before CI gets involved.
echo "Checking for migration number conflicts..."

# Fallback base branch when no upstream is set (e.g. branch created via
# manual `git checkout -b` instead of `./scripts/new-task.sh`). Should match
# the BASE_BRANCH default in scripts/new-task.sh — flip both to "main" when
# renew-pms goes live.
FALLBACK_BASE="origin/staging"
REMOTE_REF=$(git rev-parse --abbrev-ref "@{upstream}" 2>/dev/null || echo "$FALLBACK_BASE")
REMOTE_BRANCH="${REMOTE_REF#origin/}"

# Fetch latest remote state (quiet, don't fail if offline)
git fetch origin "$REMOTE_BRANCH" --quiet 2>/dev/null || true

MERGE_BASE=$(git merge-base HEAD "origin/$REMOTE_BRANCH" 2>/dev/null || echo "")
if [ -n "$MERGE_BASE" ]; then
  LOCAL_MIGRATIONS=$(ls supabase/migrations/*.sql 2>/dev/null | xargs -I{} basename {} | sort)
  BASE_MIGRATIONS=$(git ls-tree -r --name-only "$MERGE_BASE" -- supabase/migrations/ 2>/dev/null | xargs -I{} basename {} | sort)
  REMOTE_MIGRATIONS=$(git ls-tree -r --name-only "origin/$REMOTE_BRANCH" -- supabase/migrations/ 2>/dev/null | xargs -I{} basename {} | sort)

  TMPDIR_HOOK=$(mktemp -d)
  echo "$LOCAL_MIGRATIONS" > "$TMPDIR_HOOK/local"
  echo "$BASE_MIGRATIONS" > "$TMPDIR_HOOK/base"
  echo "$REMOTE_MIGRATIONS" > "$TMPDIR_HOOK/remote"

  NEW_LOCAL=$(comm -23 "$TMPDIR_HOOK/local" "$TMPDIR_HOOK/base" 2>/dev/null || true)
  NEW_REMOTE=$(comm -23 "$TMPDIR_HOOK/remote" "$TMPDIR_HOOK/base" 2>/dev/null || true)

  if [ -n "$NEW_LOCAL" ] && [ -n "$NEW_REMOTE" ]; then
    echo "$NEW_LOCAL" | sed 's/_.*//' | sort -u > "$TMPDIR_HOOK/local_nums"
    echo "$NEW_REMOTE" | sed 's/_.*//' | sort -u > "$TMPDIR_HOOK/remote_nums"
    CONFLICTS=$(comm -12 "$TMPDIR_HOOK/local_nums" "$TMPDIR_HOOK/remote_nums" 2>/dev/null || true)

    if [ -n "$CONFLICTS" ]; then
      echo ""
      echo "ERROR: Migration number conflict detected!"
      echo "These numbers exist on both your branch and origin/$REMOTE_BRANCH:"
      echo "$CONFLICTS"
      echo ""
      NEXT_NUM=$(echo "$REMOTE_MIGRATIONS" "$LOCAL_MIGRATIONS" | sed 's/_.*//' | sort -u | tail -1 | awk '{printf "%05d", $1+1}')
      echo "Renumber your migration(s). Next available: $NEXT_NUM"
      rm -rf "$TMPDIR_HOOK"
      exit 1
    fi
  fi

  rm -rf "$TMPDIR_HOOK"
fi
echo "No migration conflicts."

# ── Netlify functions server-only guard ──
# Fails if any netlify/functions entry transitively imports a `server-only`-
# guarded module — it throws at module load in the Netlify Functions runtime
# (plain Node, no `react-server` export condition) and silently freezes the
# worker. The DAL may keep `server-only`; functions just must not reach it.
# Ported from brik-client-portal #1037/#1038 (brik-client-portal#1041).
echo "Checking netlify functions for server-only reachability..."
node scripts/check-functions-no-server-only.mjs

echo "Running tests before push..."
npx vitest run --reporter=verbose
echo "Tests passed."

echo "Running clean build check before push..."

# Build into a separate directory so we don't destroy the running dev server's .next cache.
rm -rf .next-prepush
trap 'rm -rf .next-prepush' EXIT

NEXT_BUILD_OUTPUT_DIR=".next-prepush" npm run build

echo "Build passed (dev server cache untouched)."
