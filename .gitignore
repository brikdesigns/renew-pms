# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
test-results/
playwright-report/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# Keep .env.example tracked
!.env.example

# vercel
.vercel

# Supabase
.supabase

# Sentry
.sentryclirc

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Fumadocs generated
.source/

# Paper design artifacts (local only)
paper/

# Screen recordings and demo media (large binary files — store outside repo)
recordings/*.mp4
recordings/*.webm
recordings/*.gif
recordings/**/*.ttf
recordings/assembly/
recordings/analysis/
recordings/trimmed/
.playwright-mcp/
