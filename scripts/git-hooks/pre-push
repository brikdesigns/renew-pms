#!/usr/bin/env bash
# pre-push — Runs typecheck + build before allowing a push.
# Prevents broken code from reaching Netlify and burning deploy credits.
#
# To bypass in emergencies: git push --no-verify (user must explicitly request)

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

echo ""
echo "═══════════════════════════════════════"
echo "  Pre-push checks (renew-pms)"
echo "═══════════════════════════════════════"
echo ""

# ── TypeScript check ──
echo -e "${YELLOW}▸ Running typecheck...${NC}"
if npm run typecheck; then
  echo -e "${GREEN}✓ Typecheck passed${NC}"
else
  echo ""
  echo -e "${RED}✗ Typecheck failed. Fix type errors before pushing.${NC}"
  echo -e "${RED}  Push blocked.${NC}"
  exit 1
fi

echo ""

# ── Production build ──
echo -e "${YELLOW}▸ Running build...${NC}"
if npm run build; then
  echo -e "${GREEN}✓ Build passed${NC}"
else
  echo ""
  echo -e "${RED}✗ Build failed. Fix build errors before pushing.${NC}"
  echo -e "${RED}  Push blocked.${NC}"
  exit 1
fi

echo ""
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo -e "${GREEN}  All pre-push checks passed. Pushing.${NC}"
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo ""
