{
  "permissions": {
    "allow": [
      "Bash(./scripts/netlify-ops.sh:*)",
      "Bash(bash scripts/netlify-ops.sh:*)",
      "Bash(./scripts/db-health.sh:*)",
      "Bash(netlify logs:*)",
      "Bash(netlify functions:list:*)",
      "Bash(netlify status:*)",
      "mcp__supabase__*"
    ],
    "comment": "Read-only agent ops access (Netlify + Supabase). Mutating Netlify CLI (deploy, env:set, functions:invoke), the netlify MCP write tools, and ALL prod Supabase writes are deliberately omitted so they still prompt — see docs/process/agent-ops-access.md."
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/worktree-check.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/worktree-check.sh" },
          { "type": "command", "command": ".claude/hooks/secret-scanner.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bash-leak-guard.sh" }
        ]
      }
    ]
  }
}
